                const levelNames = { bronce: 'Bronce', plata: 'Plata', oro: 'Oro', diamante: 'Diamante' };
                const nextLevel = c.level === 'bronce' ? 'plata' : c.level === 'plata' ? 'oro' : c.level === 'oro' ?
                    'diamante' : 'diamante';
                const progress = c.level === 'bronce' ? Math.min((c.points / 50) * 100, 100) :
                    c.level === 'plata' ? Math.min((c.points / 100) * 100, 100) :
                    c.level === 'oro' ? Math.min((c.points / 200) * 100, 100) : 100;
                const levelColors = { bronce: '#CD7F32', plata: '#C0C0C0', oro: '#FFD700', diamante: '#4A90D9' };
                return `
                            <tr>
                                <td><strong>${c.name}</strong></td>
                                <td>${c.doc || '-'}</td>
                                <td><strong>${c.points || 0}</strong></td>
                                <td><span class="loyalty-badge ${c.level || 'bronce'}" style="background:${levelColors[c.level || 'bronce']};color:white;">${levelEmojis[c.level || 'bronce']} ${levelNames[c.level || 'bronce']}</span></td>
                                <td>${c.purchases || 0}</td>
                                <td style="min-width:120px;">
                                    <div class="loyalty-progress">
                                        <div class="progress-bar" style="width:${Math.min(progress, 100)}%;"></div>
                                    </div>
                                    <small style="font-size:10px;color:var(--text-light);">${Math.min(progress, 100).toFixed(0)}% para ${levelNames[nextLevel]}</small>
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <button class="btn-edit-sm" onclick="editClient(${c.id})"><i class="fas fa-edit"></i></button>
                                        <button class="btn-delete-sm" onclick="deleteClient(${c.id})"><i class="fas fa-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        `;
            }).join('') || '<tr><td colspan="7" style="text-align:center;color:var(--text-light);">No hay clientes registrados</td></tr>';
        }

        function renderProductsList() {
            const list = document.getElementById('productsList');
            list.innerHTML = products.map(p => `
                        <tr>
                            <td><strong>${p.code}</strong></td>
                            <td>${p.icon || '🍕'} ${p.name}</td>
                            <td>${p.category}</td>
                            <td>$${p.price.toFixed(2)}</td>
                            <td class="${p.stock <= 3 ? 'stock-low' : ''}">${p.stock <= 3 ? '⚠️ ' : ''}${p.stock}</td>
                            <td><span class="status-badge ${p.status === 'Activo' ? 'active' : 'inactive'}">${p.status}</span></td>
                            <td>
                                <div class="actions-cell">
                                    <button class="btn-edit-sm" onclick="editProduct(${p.id})"><i class="fas fa-edit"></i></button>
                                    <button class="btn-delete-sm" onclick="deleteProduct(${p.id})"><i class="fas fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    `).join('') || '<tr><td colspan="7" style="text-align:center;color:var(--text-light);">No hay productos registrados</td></tr>';
        }

        function renderOffers() {
            const list = document.getElementById('offersList');
            list.innerHTML = offers.map(o => `
                        <tr>
                            <td><strong>${o.name}</strong></td>
                            <td>${o.description || '-'}</td>
                            <td>${o.discount}%</td>
                            <td>${o.validUntil ? new Date(o.validUntil).toLocaleDateString('es-EC') : '-'}</td>
                            <td><span class="status-badge ${o.status === 'Activo' ? 'active' : 'inactive'}">${o.status}</span></td>
                            <td>
                                <div class="actions-cell">
                                    <button class="btn-edit-sm" onclick="editOffer(${o.id})"><i class="fas fa-edit"></i></button>
                                    <button class="btn-delete-sm" onclick="deleteOffer(${o.id})"><i class="fas fa-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    `).join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text-light);">No hay ofertas registradas</td></tr>';
        }

        function renderCash() {
            const total = orders.reduce((sum, o) => sum + o.total, 0);
            const efectivo = orders.filter(o => o.paymentMethod === 'efectivo').reduce((sum, o) => sum + o.total, 0);
            const tarjeta = orders.filter(o => ['tarjeta', 'transferencia', 'qr', 'mixto'].includes(o.paymentMethod))
                .reduce((sum, o) => sum + o.total, 0);
            const egresos = cashMovements.filter(m => m.type === 'egreso').reduce((sum, m) => sum + m.amount, 0);
            const ingresos = cashMovements.filter(m => m.type === 'ingreso').reduce((sum, m) => sum + m.amount, 0);

            document.getElementById('cashTotal').textContent = '$' + (total + ingresos - egresos).toFixed(2);
            document.getElementById('cashEfectivo').textContent = '$' + efectivo.toFixed(2);
            document.getElementById('cashTarjeta').textContent = '$' + tarjeta.toFixed(2);
            document.getElementById('cashEgresos').textContent = '$' + egresos.toFixed(2);

            const allMovements = [...cashMovements, ...orders.map(o => ({
                type: 'venta',
                date: o.date,
                orderNumber: o.number,
                paymentMethod: o.paymentMethod,
                amount: o.total,
                description: 'Pedido #' + String(o.number).padStart(4, '0')
            }))].sort((a, b) => new Date(b.date) - new Date(a.date)).slice(0, 30);

            document.getElementById('cashMovements').innerHTML = allMovements.map(m => {
                const typeLabels = { ingreso: '💰 Ingreso', egreso: '💸 Egreso', venta: '🛒 Venta' };
                return `<tr>
                            <td>${new Date(m.date).toLocaleString('es-EC')}</td>
                            <td>${typeLabels[m.type] || m.type}</td>
                            <td>${m.orderNumber ? '#' + String(m.orderNumber).padStart(4,'0') : '-'}</td>
                            <td>${m.paymentMethod || '-'}</td>
                            <td style="color:${m.type === 'egreso' ? 'var(--danger)' : 'var(--success)'}">
                                ${m.type === 'egreso' ? '-' : '+'}$${m.amount.toFixed(2)}
                            </td>
                            <td>${m.description || '-'}</td>
                        </tr>`;
            }).join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text-light);">Sin movimientos</td></tr>';
        }

        function updateBadges() {
            const pending = kitchenOrders.filter(o => o.status === 'pending' || o.status === 'preparing').length;
            document.getElementById('kitchenBadge').textContent = pending;
            document.getElementById('cartBadge').textContent = cart.reduce((s, i) => s + i.qty, 0);
            const lowStock = ingredients.filter(i => i.stock <= i.minStock).length;
            document.getElementById('inventoryBadge').textContent = lowStock;
        }

        function updateOrderTypeBtn() {
            const btn = document.getElementById('orderTypeBtn');
            const types = { local: '📍 Local', takeaway: '📦 Para llevar', delivery: '🚚 Delivery', scheduled: '📅 Programado' };
            btn.textContent = types[orderType] || '📍 Local';
        }

        function updateClientDisplay() {
            document.getElementById('selectedClientName').textContent = selectedClient ? selectedClient.name :
                'Consumidor Final';
            document.getElementById('selectedClientDoc').textContent = selectedClient && selectedClient.doc ?
                '| ' + selectedClient.doc : '';
            const levelEl = document.getElementById('selectedClientLevel');
            if (selectedClient && selectedClient.level && selectedClient.level !== 'bronce') {
                levelEl.textContent = selectedClient.level;
                levelEl.className = `client-level ${selectedClient.level}`;
                levelEl.style.display = 'inline';
            } else {
                levelEl.style.display = 'none';
            }
        }

        function loadScanHistory() {
            const container = document.getElementById('scanHistory');
            if (scanHistory.length === 0) {
                container.innerHTML =
                    '<div style="text-align:center;color:var(--text-light);padding:20px;">No hay escaneos registrados</div>';
                return;
            }
            container.innerHTML = [...scanHistory].reverse().slice(0, 20).map(s => `
                        <div style="padding:10px;background:var(--bg);border-radius:8px;margin-bottom:8px;border-left:4px solid ${s.success ? 'var(--success)' : 'var(--danger)'};">
                            <div style="display:flex;justify-content:space-between;">
                                <strong>${s.success ? '✅' : '❌'} Pedido #${String(s.orderNumber).padStart(4,'0')}</strong>
                                <small>${new Date(s.time).toLocaleTimeString('es-EC')}</small>
                            </div>
                            <div style="font-size:13px;color:var(--text-light);">${s.message}</div>
                        </div>
                    `).join('');
        }

        function loadSettings() {
            document.getElementById('ivaConfig').value = ivaRate;
            document.getElementById('deliveryConfig').value = deliveryValue;
            document.getElementById('businessName').value = localStorage.getItem('monarca_businessName') || 'Pizzería Monarca';
            document.getElementById('businessRuc').value = localStorage.getItem('monarca_businessRuc') || '1234567890001';
            document.getElementById('businessAddress').value = localStorage.getItem('monarca_businessAddress') ||
                'Av. Principal 123, Ambato';
            document.getElementById('businessPhone').value = localStorage.getItem('monarca_businessPhone') || '032123456';
            document.getElementById('ticketMessage').value = localStorage.getItem('monarca_ticketMessage') ||
                '¡Gracias por su visita! 🍕';
            document.getElementById('whatsappMessage').value = localStorage.getItem('monarca_whatsappMessage') ||
                '¡Gracias por su pedido! 🍕 Su pedido #%NUMBER% está siendo preparado.';

            selectPrinter(selectedPrinter);
        }

        function saveSettings() {
            ivaRate = parseFloat(document.getElementById('ivaConfig').value) || 15;
            deliveryValue = parseFloat(document.getElementById('deliveryConfig').value) || 0;
            localStorage.setItem('monarca_iva', String(ivaRate));
            localStorage.setItem('monarca_delivery', String(deliveryValue));
            localStorage.setItem('monarca_businessName', document.getElementById('businessName').value);
            localStorage.setItem('monarca_businessRuc', document.getElementById('businessRuc').value);
            localStorage.setItem('monarca_businessAddress', document.getElementById('businessAddress').value);
            localStorage.setItem('monarca_businessPhone', document.getElementById('businessPhone').value);
            localStorage.setItem('monarca_ticketMessage', document.getElementById('ticketMessage').value);
            localStorage.setItem('monarca_whatsappMessage', document.getElementById('whatsappMessage').value);
            renderCart();
            showNotification('success', '✅', 'Configuración guardada', 'Los cambios se aplicaron correctamente');
        }

        // ========================================================
        // NAVIGATION
        // ========================================================
        function setupNavigation() {
            document.querySelectorAll('.sidebar-nav li').forEach(item => {
                item.addEventListener('click', function() {
                    const module = this.dataset.module;
                    if (module) switchModule(module);
                });
            });
        }

        function switchModule(module) {
            if (!module) return;
            document.querySelectorAll('.sidebar-nav li').forEach(el => el.classList.remove('active'));
            const navItem = document.querySelector(`[data-module="${module}"]`);
            if (navItem) navItem.classList.add('active');

            document.querySelectorAll('.module-content').forEach(el => el.classList.remove('active'));
            const target = document.getElementById('module-' + module);
            if (target) target.classList.add('active');

            currentModule = module;
            const titles = {
                dashboard: 'Dashboard <small>Bienvenido, ' + (currentUser ? currentUser.name : 'Admin') + ' 👋</small>',
                pos: 'Punto de Venta <small>Vende rápido y fácil</small>',
                kitchen: 'Cocina <small>Gestiona los pedidos</small>',
                scan: 'Escanear QR <small>Verifica entregas</small>',
                orders: 'Pedidos <small>Historial completo</small>',
                stats: 'Estadísticas <small>Análisis de ventas</small>',
                clients: 'Clientes <small>⭐ Programa de Fidelidad</small>',
                products: 'Productos <small>Catálogo completo</small>',
                inventory: 'Inventario <small>Control de ingredientes</small>',
                offers: 'Ofertas <small>Promociones y descuentos</small>',
                cash: 'Caja <small>Movimientos financieros</small>',
                settings: 'Configuración <small>Ajustes del sistema</small>'
            };
            document.getElementById('pageTitle').innerHTML = titles[module] || module;
            document.getElementById('fab').classList.toggle('show', module === 'pos');

            if (module === 'scan') {
                document.getElementById('scanner-placeholder').style.display = 'flex';
            }

            if (module === 'stats') {
                loadStats(currentStatsPeriod);
            }

            if (module === 'inventory') {
                renderInventoryAlerts();
            }
        }

        // ========================================================
        // UTILITIES
        // ========================================================
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        }

        function updateClock() {
            const now = new Date();
            document.getElementById('currentTime').textContent = now.toLocaleTimeString('es-EC', { hour12: false });
        }

        function syncData() {
            showNotification('info', '🔄', 'Sincronizando con la nube...', '');
            setTimeout(() => {
                showNotification('success', '✅', 'Datos sincronizados', 'Correctamente');
            }, 1500);
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
        }

        function validateDoc() {
            const doc = document.getElementById('clientDoc').value.trim();
            const validation = document.getElementById('docValidation');
            if (doc.length === 0) {
                validation.textContent = '';
                return;
            }
            if (doc.length === 10) {
                const digits = doc.split('').map(Number);
                if (digits.some(isNaN)) {
                    validation.textContent = '❌ Solo números';
                    validation.style.color = 'var(--danger)';
                    return;
                }
                let sum = 0;
                for (let i = 0; i < 9; i++) {
                    let num = digits[i] * (i % 2 === 0 ? 2 : 1);
                    if (num > 9) num -= 9;
                    sum += num;
                }
                const verifier = (10 - (sum % 10)) % 10;
                if (verifier === digits[9]) {
                    validation.textContent = '✅ Cédula válida';
                    validation.style.color = 'var(--success)';
                } else {
                    validation.textContent = '❌ Cédula inválida';
                    validation.style.color = 'var(--danger)';
                }
            } else if (doc.length === 13) {
                if (/^\d+$/.test(doc)) {
                    validation.textContent = '✅ RUC válido';
                    validation.style.color = 'var(--success)';
                } else {
                    validation.textContent = '❌ RUC inválido (solo números)';
                    validation.style.color = 'var(--danger)';
                }
            } else {
                validation.textContent = doc.length > 0 ? `📝 ${doc.length} dígitos` : '';
                validation.style.color = 'var(--text-light)';
            }
        }

        function toggleClientFields() {
            const type = document.getElementById('clientType').value;
            const docGroup = document.getElementById('docGroup');
            if (type === 'consumidor_final') {
                docGroup.style.display = 'none';
                document.getElementById('clientDoc').value = '';
                document.getElementById('docValidation').textContent = '';
            } else {
                docGroup.style.display = 'block';
            }
        }

        // ========================================================
        // KEYBOARD SHORTCUTS
        // ========================================================
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'b') { e.preventDefault();
                toggleSidebar(); }
            if (e.ctrlKey && e.key === '1') { e.preventDefault();
                switchModule('dashboard'); }
            if (e.ctrlKey && e.key === '2') { e.preventDefault();
                switchModule('pos'); }
            if (e.ctrlKey && e.key === '3') { e.preventDefault();
                switchModule('kitchen'); }
            if (e.ctrlKey && e.key === '4') { e.preventDefault();
                switchModule('scan'); }
            if (e.ctrlKey && e.key === '5') { e.preventDefault();
                switchModule('stats'); }
            if (e.ctrlKey && e.key === '6') { e.preventDefault();
                switchModule('inventory'); }
            if (e.key === 'F12') { e.preventDefault();
                syncData(); }
            if (e.key === 'Escape') {
                closeModal('paymentModal');
                closeModal('qrModal');
                closeModal('ticketModal');
                closeModal('clientModal');
                closeModal('productModal');
                closeModal('offerModal');
                closeModal('cashModal');
                closeModal('clientSelectorModal');
                closeModal('ingredientModal');
                closeDeliveryConfirm();
            }
            if (e.key === 'Enter' && document.getElementById('paymentModal').classList.contains('show')) {
                processPayment();
            }
        });

        // ========================================================
        // CONSOLE
        // ========================================================
        console.log('%c🏰 MonarcaPOS v9.0 - SISTEMA COMPLETO', 'font-size:28px;font-weight:bold;color:#8B4513;');
        console.log('%c🍕 Pizzería Monarca - Ambato, Ecuador', 'font-size:14px;color:#D4A373;');
        console.log('%c✅ MEJORAS: Inventario | Fidelidad | Notificaciones | QR | WhatsApp | Impresión Real',
            'font-size:13px;color:#2D6A4F;');
        console.log('📊 Pedidos:', orders.length, '| 🧾 Clientes:', clients.length, '| 📦 Productos:', products.length);
        console.log('📦 Ingredientes:', ingredients.length, '| ⚠️ Stock bajo:', ingredients.filter(i => i.stock <= i
            .minStock).length);
        console.log('📱 Atajos: Ctrl+1(Dash) Ctrl+2(POS) Ctrl+3(Cocina) Ctrl+4(Scanner) Ctrl+5(Stats) Ctrl+6(Inventario) F12(Sync)');
        console.log('👤 Usuarios: admin/admin123 | vendedor/venta123');
        console.log('🖨️ Impresora:', selectedPrinter === 'thermal' ? 'Térmica (ESC/POS)' : selectedPrinter === 'pdf' ?
            'PDF' : 'WhatsApp');
        console.log('📱 Escáner QR listo para usar');

        // Cargar jsQR para fallback
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js';
        document.head.appendChild(script);

        // Cargar autoTable para PDF
        const autoTableScript = document.createElement('script');
        autoTableScript.src = 'https://cdn.jsdelivr.net/npm/jspdf-autotable@3.5.31/dist/jspdf.plugin.autotable.min.js';
        document.head.appendChild(autoTableScript);
    </script>
