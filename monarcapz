        function loadStats(period) {
            currentStatsPeriod = period;
            document.querySelectorAll('.stats-period-selector button').forEach(btn => btn.classList.remove('active'));
            document.querySelector(`.stats-period-selector button:first-child`)?.classList.add('active');

            const customFilter = document.getElementById('customDateFilter');
            if (period === 'personalizado') {
                customFilter.style.display = 'flex';
                if (!document.getElementById('statsDateFrom').value) {
                    const today = new Date();
                    const firstDay = new Date(today.getFullYear(), today.getMonth(), 1);
                    document.getElementById('statsDateFrom').value = firstDay.toISOString().split('T')[0];
                    document.getElementById('statsDateTo').value = today.toISOString().split('T')[0];
                }
            } else {
                customFilter.style.display = 'none';
            }

            let filteredOrders = [];
            let dateLabels = [];
            let title = '';
            const today = new Date();

            if (period === 'diario') {
                const todayStr = today.toDateString();
                filteredOrders = orders.filter(o => new Date(o.date).toDateString() === todayStr);
                const hours = {};
                filteredOrders.forEach(o => {
                    const h = new Date(o.date).getHours();
                    hours[h] = (hours[h] || 0) + o.total;
                });
                dateLabels = Array.from({ length: 24 }, (_, i) => `${i}:00`);
                const data = dateLabels.map(h => hours[h] || 0);
                statsData = data;
                title = 'Ventas por Hora (Hoy)';
                document.getElementById('statsChartTitle').textContent = title;
                renderStatsChart(data, dateLabels);
                renderStatsSummary(filteredOrders);
                renderStatsDetail(filteredOrders, 'hora');
            } else if (period === 'semanal') {
                const weekStart = new Date(today);
                weekStart.setDate(today.getDate() - today.getDay());
                const weekEnd = new Date(weekStart);
                weekEnd.setDate(weekStart.getDate() + 6);
                filteredOrders = orders.filter(o => {
                    const d = new Date(o.date);
                    return d >= weekStart && d <= weekEnd;
                });
                const days = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
                const data = days.map((_, i) => {
                    const d = new Date(weekStart);
                    d.setDate(weekStart.getDate() + i);
                    const dayOrders = orders.filter(o => new Date(o.date).toDateString() === d.toDateString());
                    return dayOrders.reduce((sum, o) => sum + o.total, 0);
                });
                statsData = data;
                dateLabels = days;
                title = 'Ventas por Día (Semana)';
                document.getElementById('statsChartTitle').textContent = title;
                renderStatsChart(data, dateLabels);
                renderStatsSummary(filteredOrders);
                renderStatsDetail(filteredOrders, 'día');
            } else if (period === 'mensual') {
                const monthStart = new Date(today.getFullYear(), today.getMonth(), 1);
                const monthEnd = new Date(today.getFullYear(), today.getMonth() + 1, 0);
                filteredOrders = orders.filter(o => {
                    const d = new Date(o.date);
                    return d >= monthStart && d <= monthEnd;
                });
                const daysInMonth = monthEnd.getDate();
                const data = Array.from({ length: daysInMonth }, (_, i) => {
                    const d = new Date(today.getFullYear(), today.getMonth(), i + 1);
                    const dayOrders = orders.filter(o => new Date(o.date).toDateString() === d.toDateString());
                    return dayOrders.reduce((sum, o) => sum + o.total, 0);
                });
                statsData = data;
                dateLabels = Array.from({ length: daysInMonth }, (_, i) => `${i+1}`);
                title = `Ventas por Día (${today.toLocaleString('es', { month: 'long' })})`;
                document.getElementById('statsChartTitle').textContent = title;
                renderStatsChart(data, dateLabels);
                renderStatsSummary(filteredOrders);
                renderStatsDetail(filteredOrders, 'día');
            } else if (period === 'anual') {
                const year = today.getFullYear();
                filteredOrders = orders.filter(o => new Date(o.date).getFullYear() === year);
                const months = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
                const data = months.map((_, i) => {
                    const monthOrders = orders.filter(o => {
                        const d = new Date(o.date);
                        return d.getFullYear() === year && d.getMonth() === i;
                    });
                    return monthOrders.reduce((sum, o) => sum + o.total, 0);
                });
                statsData = data;
                dateLabels = months;
                title = `Ventas por Mes (${year})`;
                document.getElementById('statsChartTitle').textContent = title;
                renderStatsChart(data, dateLabels);
                renderStatsSummary(filteredOrders);
                renderStatsDetail(filteredOrders, 'mes');
            } else if (period === 'personalizado') {
                const from = new Date(document.getElementById('statsDateFrom').value);
                const to = new Date(document.getElementById('statsDateTo').value);
                if (!from || !to || isNaN(from) || isNaN(to)) {
                    showNotification('error', '❌', 'Fechas inválidas', 'Selecciona fechas válidas');
                    return;
                }
                filteredOrders = orders.filter(o => {
                    const d = new Date(o.date);
                    return d >= from && d <= to;
                });
                const daysMap = {};
                filteredOrders.forEach(o => {
                    const key = new Date(o.date).toISOString().split('T')[0];
                    daysMap[key] = (daysMap[key] || 0) + o.total;
                });
                const sortedKeys = Object.keys(daysMap).sort();
                const data = sortedKeys.map(k => daysMap[k]);
                statsData = data;
                dateLabels = sortedKeys.map(k => {
                    const d = new Date(k);
                    return `${d.getDate()}/${d.getMonth()+1}`;
                });
                title = `Ventas (${from.toLocaleDateString()} - ${to.toLocaleDateString()})`;
                document.getElementById('statsChartTitle').textContent = title;
                renderStatsChart(data, dateLabels);
                renderStatsSummary(filteredOrders);
                renderStatsDetail(filteredOrders, 'día');
            }

            document.querySelectorAll('.stats-period-selector button').forEach(btn => {
                btn.classList.remove('active');
                if (btn.textContent.includes(period.charAt(0).toUpperCase() + period.slice(1))) {
                    btn.classList.add('active');
                }
                if (period === 'personalizado' && btn.textContent.includes('Personalizado')) {
                    btn.classList.add('active');
                }
            });
        }

        function renderStatsChart(data, labels) {
            const container = document.getElementById('statsChart');
            const maxVal = Math.max(...data, 1);
            container.innerHTML = data.map((val, i) => {
                const pct = (val / maxVal * 100);
                const colors = ['#8B4513', '#A0522D', '#CD853F', '#D4A373', '#E8C9A0', '#F4A460', '#FFD700', '#2D6A4F',
                    '#2A9D8F', '#457B9D', '#E63946', '#F77F00'
                ];
                const color = colors[i % colors.length];
                return `<div class="bar-item">
                            <div class="bar" style="height:${Math.max(pct, 5)}%;background:linear-gradient(180deg, ${color}, ${color}cc);">
                                <span class="bar-value">$${val.toFixed(0)}</span>
                            </div>
                            <span class="bar-label">${labels[i] || ''}</span>
                        </div>`;
            }).join('');
        }

        function renderStatsSummary(ordersData) {
            const totalSales = ordersData.reduce((sum, o) => sum + o.total, 0);
            const totalOrders = ordersData.length;
            const avgTicket = totalOrders > 0 ? totalSales / totalOrders : 0;
            const uniqueClients = new Set(ordersData.map(o => o.client || 'Consumidor Final')).size;

            document.getElementById('statsTotalSales').textContent = '$' + totalSales.toFixed(2);
            document.getElementById('statsTotalOrders').textContent = totalOrders;
            document.getElementById('statsAverageTicket').textContent = '$' + avgTicket.toFixed(2);
            document.getElementById('statsTotalClients').textContent = uniqueClients;
        }

        function renderStatsDetail(ordersData, groupBy) {
            const tbody = document.getElementById('statsDetailBody');
            if (ordersData.length === 0) {
                tbody.innerHTML =
                    '<tr><td colspan="5" style="text-align:center;color:var(--text-light);">No hay datos en este período</td></tr>';
                return;
            }

            let groups = {};
            if (groupBy === 'hora') {
                ordersData.forEach(o => {
                    const h = new Date(o.date).getHours();
                    const key = `${h}:00 - ${h+1}:00`;
                    if (!groups[key]) groups[key] = { orders: [], total: 0 };
                    groups[key].orders.push(o);
                    groups[key].total += o.total;
                });
            } else if (groupBy === 'día') {
                ordersData.forEach(o => {
                    const key = new Date(o.date).toISOString().split('T')[0];
                    if (!groups[key]) groups[key] = { orders: [], total: 0 };
                    groups[key].orders.push(o);
                    groups[key].total += o.total;
                });
            } else if (groupBy === 'mes') {
                ordersData.forEach(o => {
                    const d = new Date(o.date);
                    const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
                    if (!groups[key]) groups[key] = { orders: [], total: 0 };
                    groups[key].orders.push(o);
                    groups[key].total += o.total;
                });
            }

            const sortedKeys = Object.keys(groups).sort();
            tbody.innerHTML = sortedKeys.map(key => {
                const group = groups[key];
                const avg = group.orders.length > 0 ? group.total / group.orders.length : 0;
                const clients = new Set(group.orders.map(o => o.client || 'Consumidor Final')).size;
                const displayKey = key.includes('-') ? key : new Date(key).toLocaleDateString('es-EC');
                return `<tr>
                            <td><strong>${displayKey}</strong></td>
                            <td>${group.orders.length}</td>
                            <td>$${group.total.toFixed(2)}</td>
                            <td>$${avg.toFixed(2)}</td>
                            <td>${clients}</td>
                        </tr>`;
            }).join('');
        }

