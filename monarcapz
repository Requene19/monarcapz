<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏰 MonarcaPOS - Pizzería Monarca</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        /* ===== RESET Y VARIABLES ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #8B4513;
            --primary-dark: #5C2E0A;
            --primary-light: #D4A373;
            --secondary: #E8C9A0;
            --accent: #FFD700;
            --success: #2D6A4F;
            --danger: #D62828;
            --warning: #F4A261;
            --info: #2A9D8F;
            --text: #2C1810;
            --text-light: #7F6B5C;
            --bg: #FDF8F3;
            --bg-card: #FFFFFF;
            --shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            --shadow-hover: 0 20px 60px rgba(0, 0, 0, 0.12);
            --radius: 16px;
            --radius-sm: 10px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --gold: #FFD700;
            --silver: #C0C0C0;
            --bronze: #CD7F32;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            height: 100vh;
            overflow: hidden;
            display: flex;
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }
        ::-webkit-scrollbar-track {
            background: var(--secondary);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 10px;
        }

        /* ===== LOGIN ===== */
        .login-page {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--primary-dark), var(--primary));
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: opacity 0.5s ease;
        }
        .login-page.hidden {
            opacity: 0;
            pointer-events: none;
        }
        .login-box {
            background: white;
            padding: 40px;
            border-radius: var(--radius);
            width: 400px;
            max-width: 92%;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: modalIn 0.5s ease;
        }
        .login-box .logo {
            text-align: center;
            margin-bottom: 30px;
        }
        .login-box .logo .brand-icon {
            width: 70px;
            height: 70px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            color: var(--primary-dark);
            margin: 0 auto 12px;
            box-shadow: 0 8px 25px rgba(255, 215, 0, 0.3);
            animation: pulse-gold 2s ease-in-out infinite;
        }
        @keyframes pulse-gold {
            0%,
            100% {
                box-shadow: 0 8px 25px rgba(255, 215, 0, 0.3);
            }
            50% {
                box-shadow: 0 8px 45px rgba(255, 215, 0, 0.6);
            }
        }
        .login-box .logo h1 {
            color: var(--primary-dark);
            font-size: 24px;
        }
        .login-box .logo h1 span {
            color: var(--accent);
        }
        .login-box .logo p {
            color: var(--text-light);
            font-size: 14px;
        }

        /* Campos de login - Ocultos por defecto, solo visibles al enfocar */
        .login-box .form-group {
            margin-bottom: 16px;
        }
        .login-box .form-group label {
            display: block;
            font-weight: 600;
            font-size: 13px;
            color: var(--text-light);
            margin-bottom: 4px;
        }
        .login-box .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e8e8e8;
            border-radius: var(--radius-sm);
            font-size: 15px;
            transition: var(--transition);
        }
        .login-box .form-group input:focus {
            border-color: var(--primary);
            outline: none;
        }
        .login-box .login-btn {
            width: 100%;
            padding: 14px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
        }
        .login-box .login-btn:hover {
            background: var(--primary-dark);
            transform: scale(1.02);
        }
        .login-box .login-error {
            color: var(--danger);
            font-size: 13px;
            margin-top: 10px;
            text-align: center;
            display: none;
        }
        .login-box .login-error.show {
            display: block;
        }
        /* Credenciales ocultas - solo visibles al hacer hover */
        .login-credentials-hint {
            text-align: center;
            margin-top: 12px;
            font-size: 11px;
            color: var(--text-light);
            opacity: 0.3;
            transition: var(--transition);
            cursor: default;
        }
        .login-credentials-hint:hover {
            opacity: 0.8;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 250px;
            height: 100vh;
            background: linear-gradient(180deg, var(--primary-dark) 0%, var(--primary) 100%);
            padding: 20px 16px;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            box-shadow: 4px 0 30px rgba(0, 0, 0, 0.15);
            z-index: 100;
            transition: var(--transition);
            overflow: hidden;
        }
        .sidebar.collapsed {
            width: 72px;
        }
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-bottom: 20px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
        }
        .brand-icon {
            width: 44px;
            height: 44px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--primary-dark);
            flex-shrink: 0;
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
        }
        .sidebar-brand h1 {
            color: white;
            font-size: 20px;
            font-weight: 700;
        }
        .sidebar-brand h1 span {
            color: var(--accent);
        }
        .sidebar-brand small {
            color: rgba(255, 255, 255, 0.5);
            font-size: 10px;
            display: block;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        .sidebar.collapsed .sidebar-brand h1,
        .sidebar.collapsed .sidebar-brand small {
            display: none;
        }
        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
        }
        .sidebar-nav ul {
            list-style: none;
        }
        .sidebar-nav li {
            padding: 12px 14px;
            margin: 3px 0;
            border-radius: var(--radius-sm);
            color: rgba(255, 255, 255, 0.7);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: var(--transition);
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            position: relative;
        }
        .sidebar-nav li:hover {
            background: rgba(255, 255, 255, 0.08);
            color: white;
            transform: translateX(4px);
        }
        .sidebar-nav li.active {
            background: rgba(255, 215, 0, 0.15);
            color: var(--accent);
        }
        .sidebar-nav li i {
            width: 20px;
            text-align: center;
            font-size: 16px;
            flex-shrink: 0;
        }
        .sidebar-nav li .badge {
            margin-left: auto;
            background: var(--danger);
            color: white;
            padding: 1px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            animation: pulse-badge 1.5s ease-in-out infinite;
        }
        .sidebar-nav li .badge.notification {
            background: var(--accent);
            color: var(--primary-dark);
        }
        @keyframes pulse-badge {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1);
            }
        }
        .sidebar.collapsed .sidebar-nav li span:not(.badge) {
            display: none;
        }
        .sidebar.collapsed .sidebar-nav li .badge {
            display: none;
        }
        .sidebar-footer {
            border-top: 2px solid rgba(255, 255, 255, 0.1);
            padding-top: 16px;
        }
        .user-card {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-sm);
        }
        .user-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: var(--primary-dark);
            font-weight: 700;
            flex-shrink: 0;
        }
        .user-info h4 {
            color: white;
            font-size: 13px;
        }
        .user-info small {
            color: rgba(255, 255, 255, 0.4);
            font-size: 11px;
        }
        .sidebar.collapsed .user-info {
            display: none;
        }
        .logout-btn {
            margin-top: 10px;
            width: 100%;
            padding: 10px;
            background: rgba(214, 40, 40, 0.15);
            border: 1px solid rgba(214, 40, 40, 0.2);
            border-radius: var(--radius-sm);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 13px;
        }
        .logout-btn:hover {
            background: var(--danger);
            border-color: var(--danger);
        }
        .sidebar.collapsed .logout-btn span {
            display: none;
        }

        /* ===== MAIN ===== */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }
        .main-header {
            background: var(--bg-card);
            padding: 14px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
            flex-shrink: 0;
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        }
        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .toggle-btn {
            background: none;
            border: none;
            font-size: 22px;
            color: var(--primary);
            cursor: pointer;
            padding: 6px;
            border-radius: 8px;
            transition: var(--transition);
        }
        .toggle-btn:hover {
            background: var(--secondary);
        }
        .header-left h2 {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary-dark);
        }
        .header-left h2 small {
            font-weight: 400;
            color: var(--text-light);
            font-size: 13px;
            margin-left: 8px;
        }
        .header-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .header-time {
            font-weight: 600;
            color: var(--primary);
            background: var(--secondary);
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .header-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            background: var(--bg);
            color: var(--primary);
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .header-btn:hover {
            background: var(--secondary);
            transform: translateY(-2px);
        }
        .header-btn .dot {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 8px;
            height: 8px;
            background: var(--danger);
            border-radius: 50%;
            border: 2px solid white;
            animation: pulse-badge 1.5s ease-in-out infinite;
        }

        /* ===== NOTIFICACIONES ===== */
        .notification-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9998;
            max-width: 380px;
            width: 100%;
        }
        .notification {
            background: var(--primary-dark);
            color: white;
            padding: 16px 20px;
            border-radius: var(--radius-sm);
            margin-bottom: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            transform: translateX(120%);
            animation: slideInNotification 0.5s ease forwards;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 4px solid var(--accent);
        }
        .notification.success {
            border-left-color: var(--success);
        }
        .notification.warning {
            border-left-color: var(--warning);
        }
        .notification.error {
            border-left-color: var(--danger);
        }
        .notification.info {
            border-left-color: var(--info);
        }
        @keyframes slideInNotification {
            to {
                transform: translateX(0);
            }
        }
        @keyframes slideOutNotification {
            to {
                transform: translateX(120%);
                opacity: 0;
            }
        }
        .notification .n-icon {
            font-size: 24px;
            flex-shrink: 0;
        }
        .notification .n-content {
            flex: 1;
        }
        .notification .n-title {
            font-weight: 700;
            font-size: 14px;
        }
        .notification .n-message {
            font-size: 13px;
            opacity: 0.9;
        }
        .notification .n-close {
            background: none;
            border: none;
            color: white;
            cursor: pointer;
            font-size: 18px;
            opacity: 0.6;
            transition: var(--transition);
        }
        .notification .n-close:hover {
            opacity: 1;
        }

        /* ===== CONTENT ===== */
        .content-area {
            flex: 1;
            overflow-y: auto;
            padding: 24px 30px;
        }
        .module-content {
            display: none;
            animation: fadeIn 0.3s ease;
        }
        .module-content.active {
            display: block;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== CARDS Y ESTADÍSTICAS ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 24px;
        }
        .stat-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px 24px;
            box-shadow: var(--shadow);
            transition: var(--transition);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            opacity: 0;
            transition: var(--transition);
        }
        .stat-card:hover {
            transform: translateY(-6px) scale(1.01);
            box-shadow: var(--shadow-hover);
        }
        .stat-card:hover::before {
            opacity: 1;
        }
        .stat-card .stat-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        .stat-card .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            animation: float-icon 3s ease-in-out infinite;
        }
        @keyframes float-icon {
            0%,
            100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-5px);
            }
        }
        .stat-icon.gold {
            background: rgba(255, 215, 0, 0.15);
            color: #F4A460;
        }
        .stat-icon.green {
            background: rgba(45, 106, 79, 0.15);
            color: var(--success);
        }
        .stat-icon.blue {
            background: rgba(42, 157, 143, 0.15);
            color: var(--info);
        }
        .stat-icon.pink {
            background: rgba(214, 40, 40, 0.1);
            color: var(--danger);
        }
        .stat-card h3 {
            font-size: 26px;
            font-weight: 800;
            color: var(--primary-dark);
            transition: var(--transition);
        }
        .stat-card:hover h3 {
            transform: scale(1.05);
        }
        .stat-card p {
            color: var(--text-light);
            font-size: 13px;
            font-weight: 500;
        }
        .stat-change {
            padding: 3px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }
        .stat-change.up {
            background: rgba(45, 106, 79, 0.1);
            color: var(--success);
        }
        .stat-change.down {
            background: rgba(214, 40, 40, 0.1);
            color: var(--danger);
        }

        /* ===== GRÁFICOS ===== */
        .charts-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }
        .chart-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px 24px;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }
        .chart-card:hover {
            box-shadow: var(--shadow-hover);
            transform: scale(1.01);
        }
        .chart-card h4 {
            font-size: 15px;
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* ===== BAR CHART ===== */
        .bar-chart {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            height: 180px;
            gap: 10px;
        }
        .bar-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            flex: 1;
        }
        .bar {
            width: 100%;
            max-width: 40px;
            border-radius: 6px 6px 0 0;
            background: linear-gradient(180deg, var(--primary), var(--primary-light));
            transition: height 1.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            min-height: 10px;
            cursor: pointer;
            position: relative;
            box-shadow: 0 4px 15px rgba(139, 69, 19, 0.2);
        }
        .bar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 30%;
            background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.2));
            border-radius: 0 0 6px 6px;
        }
        .bar:hover {
            filter: brightness(1.15);
            transform: scaleY(1.05);
        }
        .bar .bar-value {
            position: absolute;
            top: -24px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 11px;
            font-weight: 700;
            color: var(--primary-dark);
            opacity: 0;
            transition: var(--transition);
            background: white;
            padding: 2px 8px;
            border-radius: 4px;
            box-shadow: var(--shadow);
        }
        .bar:hover .bar-value {
            opacity: 1;
        }
        .bar-label {
            font-size: 10px;
            font-weight: 600;
            color: var(--text-light);
            margin-top: 4px;
        }

        /* ===== TABLAS ===== */
        .orders-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px 24px;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }
        .orders-card:hover {
            box-shadow: var(--shadow-hover);
        }
        .section-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .section-title h3 {
            font-size: 17px;
            font-weight: 700;
            color: var(--primary-dark);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .section-title .actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .section-title .actions button {
            padding: 6px 16px;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: var(--transition);
        }
        .section-title .actions .btn-add {
            background: var(--primary);
            color: white;
        }
        .section-title .actions .btn-add:hover {
            background: var(--primary-dark);
            transform: scale(1.05);
        }
        .section-title .actions .btn-edit {
            background: var(--info);
            color: white;
        }
        .section-title .actions .btn-edit:hover {
            background: #1A7A6E;
            transform: scale(1.05);
        }
        .section-title .actions .btn-delete {
            background: var(--danger);
            color: white;
        }
        .section-title .actions .btn-delete:hover {
            background: #A01C1C;
            transform: scale(1.05);
        }
        .section-title .actions .btn-pdf {
            background: #DC143C;
            color: white;
        }
        .section-title .actions .btn-pdf:hover {
            background: #B01030;
            transform: scale(1.05);
        }
        .section-title .view-all {
            color: var(--primary);
            font-weight: 600;
            cursor: pointer;
            font-size: 13px;
            transition: var(--transition);
        }
        .section-title .view-all:hover {
            color: var(--accent);
            transform: translateX(4px);
        }

        .orders-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        .orders-table th {
            text-align: left;
            padding: 10px 12px;
            color: var(--text-light);
            font-weight: 600;
            border-bottom: 2px solid var(--secondary);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .orders-table td {
            padding: 10px 12px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.04);
            vertical-align: middle;
        }
        .orders-table tr {
            transition: var(--transition);
        }
        .orders-table tr:hover td {
            background: rgba(212, 163, 115, 0.06);
        }
        .orders-table .actions-cell {
            display: flex;
            gap: 6px;
        }
        .orders-table .actions-cell button {
            padding: 4px 10px;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }
        .orders-table .actions-cell .btn-edit-sm {
            background: var(--info);
            color: white;
        }
        .orders-table .actions-cell .btn-edit-sm:hover {
            background: #1A7A6E;
            transform: scale(1.05);
        }
        .orders-table .actions-cell .btn-delete-sm {
            background: var(--danger);
            color: white;
        }
        .orders-table .actions-cell .btn-delete-sm:hover {
            background: #A01C1C;
            transform: scale(1.05);
        }

        .status-badge {
            padding: 3px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
            animation: pulse-status 2s ease-in-out infinite;
        }
        @keyframes pulse-status {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.03);
            }
        }
        .status-badge.pending {
            background: rgba(244, 162, 97, 0.15);
            color: var(--warning);
        }
        .status-badge.preparing {
            background: rgba(42, 157, 143, 0.15);
            color: var(--info);
        }
        .status-badge.ready {
            background: rgba(45, 106, 79, 0.15);
            color: var(--success);
        }
        .status-badge.delivered {
            background: rgba(139, 69, 19, 0.1);
            color: var(--primary);
        }
        .status-badge.active {
            background: rgba(45, 106, 79, 0.15);
            color: var(--success);
        }
        .status-badge.inactive {
            background: rgba(214, 40, 40, 0.1);
            color: var(--danger);
        }
        .status-badge.stock-low {
            background: rgba(214, 40, 40, 0.15);
            color: var(--danger);
            animation: pulse-stock 1s ease-in-out infinite;
        }
        @keyframes pulse-stock {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.05);
            }
        }

        /* ===== POS ===== */
        .pos-container {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 20px;
            height: calc(100vh - 180px);
        }
        .pos-products {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
        }
        .pos-header {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }
        .pos-header .search-box {
            flex: 1;
            position: relative;
            min-width: 150px;
        }
        .pos-header .search-box i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #999;
        }
        .pos-header .search-box input {
            width: 100%;
            padding: 10px 14px 10px 42px;
            border: 2px solid #e8e8e8;
            border-radius: var(--radius-sm);
            font-size: 14px;
            transition: var(--transition);
        }
        .pos-header .search-box input:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
        }
        .pos-header select {
            padding: 10px 14px;
            border: 2px solid #e8e8e8;
            border-radius: var(--radius-sm);
            font-size: 14px;
            background: white;
            cursor: pointer;
            transition: var(--transition);
        }
        .pos-header select:focus {
            border-color: var(--primary);
            outline: none;
        }
        .products-grid {
            flex: 1;
            overflow-y: auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 12px;
            padding: 4px;
        }
        .product-card {
            background: var(--bg);
            border-radius: var(--radius-sm);
            padding: 14px;
            text-align: center;
            transition: var(--transition);
            cursor: pointer;
            border: 2px solid transparent;
            position: relative;
        }
        .product-card:hover {
            transform: translateY(-6px) scale(1.02);
            box-shadow: var(--shadow-hover);
            border-color: var(--primary-light);
        }
        .product-card .p-icon {
            font-size: 32px;
            color: var(--primary);
            margin-bottom: 6px;
            transition: var(--transition);
        }
        .product-card:hover .p-icon {
            transform: scale(1.15) rotate(-10deg);
        }
        .product-card h5 {
            font-size: 13px;
            font-weight: 600;
        }
        .product-card .p-price {
            font-weight: 700;
            color: var(--primary);
            font-size: 15px;
            margin-top: 4px;
        }
        .product-card .p-stock {
            font-size: 11px;
            color: var(--text-light);
        }
        .product-card .p-stock.low-stock {
            color: var(--danger);
            font-weight: 700;
            animation: pulse-stock 1s ease-in-out infinite;
        }
        .product-card .add-btn {
            position: absolute;
            bottom: 8px;
            right: 8px;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: none;
            background: var(--primary);
            color: white;
            cursor: pointer;
            font-size: 14px;
            transition: var(--transition);
        }
        .product-card .add-btn:hover {
            transform: scale(1.2) rotate(90deg);
            background: var(--primary-dark);
        }

        /* ===== CARRITO ===== */
        .pos-cart {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
        }
        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            padding-bottom: 12px;
            border-bottom: 2px solid var(--secondary);
        }
        .cart-header h4 {
            color: var(--primary-dark);
            font-size: 16px;
        }
        .cart-header h4 span {
            color: var(--primary);
        }
        .cart-header .clear-btn {
            background: none;
            border: none;
            color: var(--danger);
            cursor: pointer;
            font-size: 16px;
            transition: var(--transition);
        }
        .cart-header .clear-btn:hover {
            transform: scale(1.15) rotate(90deg);
        }
        .cart-items {
            flex: 1;
            overflow-y: auto;
            margin-bottom: 12px;
        }
        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #f0f0f0;
            animation: slideInItem 0.3s ease;
        }
        @keyframes slideInItem {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        .cart-item .item-info {
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .cart-item .item-name {
            font-weight: 500;
            font-size: 13px;
        }
        .cart-item .item-qty {
            color: var(--text-light);
            font-size: 13px;
        }
        .cart-item .item-price {
            font-weight: 600;
            font-size: 13px;
        }
        .cart-item .item-actions {
            display: flex;
            gap: 6px;
        }
        .cart-item .item-actions button {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            border: none;
            cursor: pointer;
            font-size: 12px;
            transition: var(--transition);
        }
        .cart-item .item-actions .qty-btn {
            background: var(--secondary);
            color: var(--primary);
        }
        .cart-item .item-actions .qty-btn:hover {
            background: var(--primary);
            color: white;
            transform: scale(1.1);
        }
        .cart-item .item-actions .remove-btn {
            background: rgba(214, 40, 40, 0.1);
            color: var(--danger);
        }
        .cart-item .item-actions .remove-btn:hover {
            background: var(--danger);
            color: white;
            transform: scale(1.1);
        }
        .cart-summary {
            border-top: 2px solid var(--secondary);
            padding-top: 12px;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 4px 0;
            font-size: 14px;
            color: var(--text-light);
        }
        .summary-row .edit-delivery {
            color: var(--info);
            cursor: pointer;
            font-size: 12px;
            margin-left: 8px;
        }
        .summary-row .edit-delivery:hover {
            text-decoration: underline;
        }
        .summary-row.total {
            font-weight: 700;
            font-size: 18px;
            color: var(--primary-dark);
            border-top: 2px solid #e0e0e0;
            padding-top: 8px;
            margin-top: 4px;
        }
        .summary-row.total span:last-child {
            color: var(--primary);
            font-size: 20px;
        }
        .cart-actions {
            display: flex;
            gap: 10px;
            margin-top: 12px;
        }
        .cart-actions button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .cart-actions button:hover {
            transform: scale(1.02);
        }
        .btn-pay {
            background: var(--success);
            color: white;
        }
        .btn-pay:hover {
            background: #1B4D3E;
            box-shadow: 0 5px 20px rgba(45, 106, 79, 0.3);
        }
        .btn-pay:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        .btn-order-type {
            background: var(--secondary);
            color: var(--primary);
            flex: 0.6;
            font-size: 13px;
        }
        .btn-order-type:hover {
            background: var(--primary);
            color: white;
        }

        /* ===== SELECTOR DE CLIENTE ===== */
        .client-selector {
            display: flex;
            gap: 8px;
            align-items: center;
            background: var(--bg);
            padding: 8px 12px;
            border-radius: var(--radius-sm);
            border: 2px solid #e8e8e8;
            min-width: 200px;
            cursor: pointer;
            transition: var(--transition);
            margin-bottom: 12px;
        }
        .client-selector:hover {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
        }
        .client-selector .client-info {
            flex: 1;
            font-size: 13px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .client-selector .client-info .client-name {
            font-weight: 600;
            color: var(--primary-dark);
        }
        .client-selector .client-info .client-doc {
            font-size: 11px;
            color: var(--text-light);
            margin-left: 6px;
        }
        .client-selector .client-info .client-level {
            font-size: 10px;
            margin-left: 6px;
            padding: 1px 8px;
            border-radius: 10px;
        }
        .client-selector .client-info .client-level.bronce {
            background: #CD7F32;
            color: white;
        }
        .client-selector .client-info .client-level.plata {
            background: #C0C0C0;
            color: #333;
        }
        .client-selector .client-info .client-level.oro {
            background: #FFD700;
            color: #333;
        }
        .client-selector .client-info .client-level.diamante {
            background: #4A90D9;
            color: white;
        }
        .client-selector .client-icon {
            font-size: 16px;
            color: var(--primary);
        }
        .client-selector .client-arrow {
            font-size: 12px;
            color: var(--text-light);
        }

        /* ===== MODALES ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(4px);
        }
        .modal-overlay.show {
            display: flex;
        }
        .modal {
            background: white;
            border-radius: var(--radius);
            width: 520px;
            max-width: 94%;
            max-height: 92vh;
            overflow-y: auto;
            padding: 28px 32px;
            animation: modalIn 0.3s ease;
        }
        .modal-sm {
            width: 420px;
        }
        .modal-lg {
            width: 90%;
            max-width: 1000px;
        }
        @keyframes modalIn {
            from {
                transform: scale(0.9) translateY(20px);
                opacity: 0;
            }
            to {
                transform: scale(1) translateY(0);
                opacity: 1;
            }
        }
        .modal h2 {
            color: var(--primary-dark);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .modal .form-group {
            margin-bottom: 14px;
        }
        .modal .form-group label {
            display: block;
            font-weight: 600;
            font-size: 13px;
            color: var(--text-light);
            margin-bottom: 4px;
        }
        .modal .form-group label .required {
            color: var(--danger);
        }
        .modal .form-group input,
        .modal .form-group select,
        .modal .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid #e8e8e8;
            border-radius: var(--radius-sm);
            font-size: 14px;
            transition: var(--transition);
            font-family: inherit;
        }
        .modal .form-group input:focus,
        .modal .form-group select:focus,
        .modal .form-group textarea:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
        }
        .modal .form-group textarea {
            resize: vertical;
            min-height: 60px;
        }
        .modal .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .modal .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }
        .modal .modal-actions button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: var(--transition);
        }
        .modal .modal-actions .btn-confirm {
            background: var(--success);
            color: white;
        }
        .modal .modal-actions .btn-confirm:hover {
            background: #1B4D3E;
            transform: scale(1.02);
        }
        .modal .modal-actions .btn-cancel {
            background: #e8e8e8;
            color: var(--text);
        }
        .modal .modal-actions .btn-cancel:hover {
            background: #d0d0d0;
        }
        .modal .modal-actions .btn-danger-action {
            background: var(--danger);
            color: white;
        }
        .modal .modal-actions .btn-danger-action:hover {
            background: #A01C1C;
            transform: scale(1.02);
        }
        .modal .modal-actions .btn-pdf-action {
            background: #DC143C;
            color: white;
        }
        .modal .modal-actions .btn-pdf-action:hover {
            background: #B01030;
            transform: scale(1.02);
        }

        /* ===== QR Y TICKET ===== */
        .qr-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 16px;
            padding: 10px 0;
        }
        .qr-container #qrcode {
            background: white;
            padding: 16px;
            border-radius: var(--radius-sm);
            box-shadow: var(--shadow);
            transition: var(--transition);
        }
        .qr-container #qrcode:hover {
            transform: scale(1.05);
            box-shadow: var(--shadow-hover);
        }
        .qr-container .qr-info {
            text-align: center;
            font-size: 14px;
            color: var(--text-light);
        }
        .qr-container .qr-info strong {
            color: var(--primary-dark);
        }

        /* ===== TICKET PREVIEW CON QR CENTRADO ===== */
        .ticket-preview {
            background: white;
            padding: 20px;
            border-radius: var(--radius-sm);
            border: 2px dashed var(--secondary);
            font-family: 'Courier New', monospace;
            font-size: 12px;
            max-width: 340px;
            margin: 0 auto;
            line-height: 1.8;
            text-align: left;
        }
        .ticket-preview .center {
            text-align: center;
        }
        .ticket-preview .line {
            border-top: 1px dashed #999;
            margin: 8px 0;
        }
        .ticket-preview .line-double {
            border-top: 2px solid #333;
            margin: 8px 0;
        }
        .ticket-preview .total-line {
            border-top: 2px solid #333;
            margin: 6px 0;
            font-weight: 700;
            font-size: 16px;
        }
        .ticket-preview .qr-section {
            text-align: center;
            margin: 12px 0;
            padding: 12px;
            background: #f9f9f9;
            border-radius: 8px;
            border: 2px solid #e8e8e8;
        }
        .ticket-preview .qr-section .qr-title {
            font-weight: 700;
            font-size: 14px;
            color: var(--primary-dark);
            margin-bottom: 8px;
        }
        .ticket-preview .qr-section .qr-sub {
            font-size: 10px;
            color: var(--text-light);
            margin-top: 6px;
        }
        .ticket-preview .qr-section #ticketQR {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 160px;
        }
        .ticket-preview .qr-section #ticketQR canvas {
            width: 160px !important;
            height: 160px !important;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }
        .ticket-preview .header-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--primary-dark);
        }
        .ticket-preview .header-sub {
            font-size: 11px;
            color: var(--text-light);
        }
        .ticket-preview .order-number {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary);
        }
        .ticket-preview .item-row {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
        }
        .ticket-preview .item-row .item-name {
            flex: 1;
        }
        .ticket-preview .item-row .item-qty {
            margin: 0 8px;
            color: var(--text-light);
        }
        .ticket-preview .item-row .item-price {
            font-weight: 600;
        }
        .ticket-preview .loyalty-info {
            background: var(--secondary);
            padding: 6px 10px;
            border-radius: 4px;
            margin: 6px 0;
            font-size: 11px;
            text-align: center;
        }

        /* ===== CONFIGURACIÓN DE IMPRESORA ===== */
        .printer-config {
            background: var(--bg);
            padding: 16px;
            border-radius: var(--radius-sm);
            margin-bottom: 12px;
        }
        .printer-config .printer-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            background: white;
            border-radius: var(--radius-sm);
            border: 2px solid #e8e8e8;
            margin-bottom: 8px;
            cursor: pointer;
            transition: var(--transition);
        }
        .printer-config .printer-item:hover {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(139, 69, 19, 0.1);
        }
        .printer-config .printer-item.selected {
            border-color: var(--success);
            background: rgba(45, 106, 79, 0.05);
        }
        .printer-config .printer-item .printer-icon {
            font-size: 24px;
            color: var(--primary);
        }
        .printer-config .printer-item .printer-info {
            flex: 1;
        }
        .printer-config .printer-item .printer-info .printer-name {
            font-weight: 600;
            font-size: 14px;
        }
        .printer-config .printer-item .printer-info .printer-status {
            font-size: 12px;
            color: var(--text-light);
        }
        .printer-config .printer-item .printer-check {
            color: var(--success);
            font-size: 20px;
        }
        .printer-config .printer-item .printer-detect {
            color: var(--info);
            font-size: 14px;
            animation: pulse-badge 1.5s ease-in-out infinite;
        }

        /* ===== COCINA ===== */
        .kitchen-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }
        .kitchen-column {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px;
            box-shadow: var(--shadow);
            min-height: 300px;
            transition: var(--transition);
        }
        .kitchen-column:hover {
            box-shadow: var(--shadow-hover);
        }
        .kitchen-column h4 {
            font-size: 15px;
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 12px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--secondary);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .kitchen-column .order-item {
            background: var(--bg);
            border-radius: var(--radius-sm);
            padding: 14px;
            margin-bottom: 10px;
            border-left: 4px solid var(--primary);
            transition: var(--transition);
            animation: slideInItem 0.3s ease;
        }
        .kitchen-column .order-item:hover {
            transform: translateX(6px) scale(1.01);
            box-shadow: var(--shadow);
        }
        .kitchen-column .order-item .order-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }
        .kitchen-column .order-item .order-header strong {
            color: var(--primary-dark);
            font-size: 15px;
        }
        .kitchen-column .order-item .order-header .qr-icon {
            cursor: pointer;
            color: var(--primary);
            transition: var(--transition);
            font-size: 16px;
        }
        .kitchen-column .order-item .order-header .qr-icon:hover {
            transform: scale(1.3);
            color: var(--accent);
        }
        .kitchen-column .order-item .order-items {
            font-size: 13px;
            color: var(--text);
        }
        .kitchen-column .order-item .order-actions {
            margin-top: 8px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .kitchen-column .order-item .order-actions button {
            padding: 4px 14px;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }
        .kitchen-column .order-item .order-actions button:hover {
            transform: scale(1.05);
        }
        .kitchen-column .order-item .order-actions .btn-prepare {
            background: var(--info);
            color: white;
        }
        .kitchen-column .order-item .order-actions .btn-prepare:hover {
            background: #1A7A6E;
        }
        .kitchen-column .order-item .order-actions .btn-ready {
            background: var(--success);
            color: white;
        }
        .kitchen-column .order-item .order-actions .btn-ready:hover {
            background: #1B4D3E;
        }
        .kitchen-column .order-item .order-actions .btn-deliver {
            background: var(--primary);
            color: white;
        }
        .kitchen-column .order-item .order-actions .btn-deliver:hover {
            background: var(--primary-dark);
        }
        .kitchen-column .order-item .order-actions .btn-verify {
            background: var(--accent);
            color: var(--primary-dark);
        }
        .kitchen-column .order-item .order-actions .btn-verify:hover {
            background: #E6C200;
        }

        /* ===== SCANNER ===== */
        #scanner-container {
            width: 100%;
            border-radius: var(--radius-sm);
            overflow: hidden;
            background: #000;
            min-height: 300px;
            position: relative;
        }
        #scanner-container video {
            width: 100%;
            height: auto;
        }
        .scanner-controls {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }
        .scanner-controls button {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }
        .scanner-controls .btn-start {
            background: var(--success);
            color: white;
        }
        .scanner-controls .btn-start:hover {
            background: #1B4D3E;
            transform: scale(1.02);
        }
        .scanner-controls .btn-stop {
            background: var(--danger);
            color: white;
        }
        .scanner-controls .btn-stop:hover {
            background: #A01C1C;
            transform: scale(1.02);
        }
        .scanner-result {
            margin-top: 12px;
            padding: 12px;
            border-radius: var(--radius-sm);
            background: var(--secondary);
            display: none;
        }
        .scanner-result.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }
        .scanner-result .result-success {
            color: var(--success);
            font-weight: 600;
        }
        .scanner-result .result-error {
            color: var(--danger);
            font-weight: 600;
        }

        /* ===== ESTADÍSTICAS ===== */
        .stats-period-selector {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }
        .stats-period-selector button {
            padding: 8px 20px;
            border: 2px solid #e8e8e8;
            border-radius: var(--radius-sm);
            background: white;
            cursor: pointer;
            font-weight: 600;
            transition: var(--transition);
            font-size: 13px;
        }
        .stats-period-selector button:hover {
            border-color: var(--primary);
            background: var(--secondary);
        }
        .stats-period-selector button.active {
            border-color: var(--primary);
            background: var(--primary);
            color: white;
        }
        .stats-summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }
        .stats-summary-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 16px 20px;
            box-shadow: var(--shadow);
            text-align: center;
        }
        .stats-summary-card h4 {
            font-size: 13px;
            color: var(--text-light);
            font-weight: 600;
            margin-bottom: 4px;
        }
        .stats-summary-card .value {
            font-size: 24px;
            font-weight: 800;
            color: var(--primary-dark);
        }
        .stats-summary-card .value.green {
            color: var(--success);
        }
        .stats-summary-card .value.red {
            color: var(--danger);
        }
        .stats-summary-card .value.gold {
            color: #F4A460;
        }
        .stats-chart-container {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px;
            box-shadow: var(--shadow);
            margin-bottom: 20px;
        }
        .stats-chart-container h4 {
            font-size: 15px;
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 16px;
        }
        .stats-table-container {
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 20px;
            box-shadow: var(--shadow);
            overflow-x: auto;
        }
        .stats-table-container h4 {
            font-size: 15px;
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 16px;
        }

        /* ===== INVENTARIO ===== */
        .inventory-alerts {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }
        .inventory-alert {
            background: var(--bg-card);
            border-radius: var(--radius-sm);
            padding: 12px 16px;
            border-left: 4px solid var(--danger);
            box-shadow: var(--shadow);
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .inventory-alert .alert-icon {
            font-size: 24px;
            color: var(--danger);
        }
        .inventory-alert .alert-info {
            flex: 1;
        }
        .inventory-alert .alert-info .alert-name {
            font-weight: 600;
            font-size: 14px;
        }
        .inventory-alert .alert-info .alert-stock {
            font-size: 12px;
            color: var(--text-light);
        }

        /* ===== TOAST ===== */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--primary-dark);
            color: white;
            padding: 14px 24px;
            border-radius: var(--radius-sm);
            box-shadow: var(--shadow-hover);
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.4s ease;
            z-index: 9999;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }
        .toast.success {
            background: var(--success);
        }
        .toast.error {
            background: var(--danger);
        }
        .toast.warning {
            background: var(--warning);
            color: var(--text);
        }

        /* ===== FAB ===== */
        .fab {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            font-size: 24px;
            box-shadow: 0 8px 30px rgba(139, 69, 19, 0.4);
            cursor: pointer;
            transition: var(--transition);
            z-index: 500;
            display: none;
            align-items: center;
            justify-content: center;
        }
        .fab:hover {
            transform: scale(1.15) rotate(90deg);
            box-shadow: 0 12px 40px rgba(139, 69, 19, 0.6);
        }
        .fab.show {
            display: flex;
        }

        /* ===== LOYALTY BADGE ===== */
        .loyalty-badge {
            display: inline-block;
            padding: 2px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
        }
        .loyalty-badge.bronce {
            background: #CD7F32;
            color: white;
        }
        .loyalty-badge.plata {
            background: #C0C0C0;
            color: #333;
        }
        .loyalty-badge.oro {
            background: #FFD700;
            color: #333;
        }
        .loyalty-badge.diamante {
            background: #4A90D9;
            color: white;
        }
        .loyalty-progress {
            width: 100%;
            height: 6px;
            background: #e8e8e8;
            border-radius: 3px;
            overflow: hidden;
            margin-top: 4px;
        }
        .loyalty-progress .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #CD7F32, #FFD700, #4A90D9);
            border-radius: 3px;
            transition: width 1s ease;
        }

        /* ===== ALERTA DE CLIENTE DUPLICADO ===== */
        .alert-duplicate {
            background: rgba(214, 40, 40, 0.1);
            border: 2px solid var(--danger);
            color: var(--danger);
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            margin-bottom: 12px;
            display: none;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            animation: shake 0.5s ease;
        }
        .alert-duplicate.show {
            display: flex;
        }
        @keyframes shake {
            0%,
            100% {
                transform: translateX(0);
            }
            25% {
                transform: translateX(-10px);
            }
            75% {
                transform: translateX(10px);
            }
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 1200px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .stats-summary-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .charts-grid {
                grid-template-columns: 1fr;
            }
            .pos-container {
                grid-template-columns: 1fr;
                height: auto;
            }
            .pos-products {
                height: 400px;
            }
            .kitchen-grid {
                grid-template-columns: 1fr;
            }
        }
        @media (max-width: 768px) {
            .sidebar {
                width: 72px;
            }
            .sidebar .sidebar-brand h1,
            .sidebar .sidebar-brand small,
            .sidebar .sidebar-nav li span:not(.badge),
            .sidebar .sidebar-nav li .badge,
            .sidebar .user-info {
                display: none;
            }
            .stats-grid {
                grid-template-columns: 1fr;
            }
            .stats-summary-grid {
                grid-template-columns: 1fr;
            }
            .content-area {
                padding: 16px;
            }
            .header-left h2 small {
                display: none;
            }
            .header-time {
                font-size: 11px;
                padding: 4px 12px;
            }
            .products-grid {
                grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            }
            .modal {
                padding: 20px;
            }
            .modal .form-row {
                grid-template-columns: 1fr;
            }
            .login-box {
                padding: 24px;
            }
            .orders-table {
                font-size: 12px;
            }
            .orders-table th,
            .orders-table td {
                padding: 6px 8px;
            }
            .pos-container {
                grid-template-columns: 1fr;
            }
            .pos-cart {
                max-height: 450px;
            }
            .notification-container {
                max-width: 300px;
                right: 10px;
                top: 10px;
            }
            .stats-period-selector button {
                padding: 6px 12px;
                font-size: 12px;
            }
            .modal-lg {
                width: 98%;
                padding: 16px;
            }
            .ticket-preview {
                max-width: 300px;
            }
            .ticket-preview .qr-section #ticketQR canvas {
                width: 120px !important;
                height: 120px !important;
            }
        }
    </style>
</head>
<body>

    <!-- ===== LOGIN ===== -->
    <div class="login-page" id="loginPage">
        <div class="login-box">
            <div class="logo">
                <div class="brand-icon">🏰</div>
                <h1>Monarca<span>POS</span></h1>
                <p>Pizzería Monarca - Ambato, Ecuador</p>
            </div>
            <form id="loginForm" onsubmit="login(event)">
                <div class="form-group">
                    <label>Usuario</label>
                    <input type="text" id="loginUser" placeholder="Ingrese su usuario" required>
                </div>
                <div class="form-group">
                    <label>Contraseña</label>
                    <input type="password" id="loginPass" placeholder="Ingrese su contraseña" required>
                </div>
                <button type="submit" class="login-btn">Iniciar Sesión</button>
                <div class="login-error" id="loginError">Usuario o contraseña incorrectos</div>
            </form>
            <div class="login-credentials-hint">🔄 Pase el mouse sobre este texto para ver credenciales de prueba</div>
        </div>
    </div>

    <!-- ===== NOTIFICACIONES ===== -->
    <div class="notification-container" id="notificationContainer"></div>

    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">🏰</div>
            <div>
                <h1>Monarca<span>POS</span></h1>
                <small>Pizzería Monarca</small>
            </div>
        </div>
        <nav class="sidebar-nav">
            <ul>
                <li class="active" data-module="dashboard">
                    <i class="fas fa-chart-pie"></i><span>Dashboard</span>
                </li>
                <li data-module="pos">
                    <i class="fas fa-cash-register"></i><span>Punto de Venta</span>
                    <span class="badge" id="cartBadge">0</span>
                </li>
                <li data-module="kitchen">
                    <i class="fas fa-utensils"></i><span>Cocina</span>
                    <span class="badge" id="kitchenBadge">0</span>
                </li>
                <li data-module="scan">
                    <i class="fas fa-qrcode"></i><span>Escanear QR</span>
                </li>
                <li data-module="orders">
                    <i class="fas fa-clipboard-list"></i><span>Pedidos</span>
                </li>
                <li data-module="stats">
                    <i class="fas fa-chart-line"></i><span>Estadísticas</span>
                </li>
                <li data-module="clients">
                    <i class="fas fa-users"></i><span>Clientes</span>
                    <span class="badge notification">⭐</span>
                </li>
                <li data-module="products">
                    <i class="fas fa-pizza-slice"></i><span>Productos</span>
                </li>
                <li data-module="inventory">
                    <i class="fas fa-boxes"></i><span>Inventario</span>
                    <span class="badge" id="inventoryBadge">0</span>
                </li>
                <li data-module="offers">
                    <i class="fas fa-tags"></i><span>Ofertas</span>
                </li>
                <li data-module="cash">
                    <i class="fas fa-money-bill-wave"></i><span>Caja</span>
                </li>
                <li data-module="settings">
                    <i class="fas fa-cog"></i><span>Configuración</span>
                </li>
            </ul>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar" id="userAvatar">👨</div>
                <div class="user-info">
                    <h4 id="userName">Administrador</h4>
                    <small id="userRole">admin@monarca.com</small>
                </div>
            </div>
            <button class="logout-btn" onclick="logout()">
                <i class="fas fa-sign-out-alt"></i><span>Cerrar Sesión</span>
            </button>
        </div>
    </aside>

    <!-- ===== MAIN ===== -->
    <main class="main-content" id="mainContent" style="display:none;">
        <header class="main-header">
            <div class="header-left">
                <button class="toggle-btn" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <h2 id="pageTitle">Dashboard <small>Bienvenido, Admin 👋</small></h2>
            </div>
            <div class="header-right">
                <div class="header-time"><i class="fas fa-clock"></i><span id="currentTime">12:00:00</span></div>
                <button class="header-btn" onclick="syncData()"><i class="fas fa-sync-alt"></i></button>
                <button class="header-btn" onclick="openScanner()"><i class="fas fa-qrcode"></i></button>
                <button class="header-btn" onclick="detectPrinter()"><i class="fas fa-print"></i><span class="dot" id="printerDot"></span></button>
            </div>
        </header>

        <div class="content-area" id="contentArea">
            <!-- ===== DASHBOARD ===== -->
            <div class="module-content active" id="module-dashboard">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-top">
                            <div class="stat-icon gold"><i class="fas fa-ticket-alt"></i></div>
                            <span class="stat-change up"><i class="fas fa-arrow-up"></i> 12%</span>
                        </div>
                        <h3 id="todaySales">$0.00</h3>
                        <p>Ventas de hoy</p>
                    </div>
                    <div class="stat-card">
                        <div class="stat-top">
                            <div class="stat-icon green"><i class="fas fa-shopping-bag"></i></div>
                            <span class="stat-change up"><i class="fas fa-arrow-up"></i> 8%</span>
                        </div>
                        <h3 id="todayOrders">0</h3>
                        <p>Pedidos hoy</p>
                    </div>
                    <div class="stat-card">
                        <div class="stat-top">
                            <div class="stat-icon blue"><i class="fas fa-users"></i></div>
                            <span class="stat-change up"><i class="fas fa-arrow-up"></i> 5%</span>
                        </div>
                        <h3 id="totalClients">0</h3>
                        <p>Clientes totales</p>
                    </div>
                    <div class="stat-card">
                        <div class="stat-top">
                            <div class="stat-icon pink"><i class="fas fa-pizza-slice"></i></div>
                            <span class="stat-change down"><i class="fas fa-arrow-down"></i> 2%</span>
                        </div>
                        <h3 id="totalProducts">0</h3>
                        <p>Productos activos</p>
                    </div>
                </div>

                <div class="charts-grid">
                    <div class="chart-card">
                        <h4><i class="fas fa-chart-bar"></i> Ventas de la semana</h4>
                        <div class="bar-chart" id="weeklyChart"></div>
                    </div>
                    <div class="chart-card">
                        <h4><i class="fas fa-crown"></i> Top productos</h4>
                        <div class="top-products" id="topProducts"></div>
                    </div>
                </div>

                <div class="orders-card">
                    <div class="section-title">
                        <h3><i class="fas fa-clock" style="color:var(--accent)"></i> Pedidos recientes</h3>
                        <span class="view-all" onclick="switchModule('orders')">Ver todos →</span>
                    </div>
                    <table class="orders-table">
                        <thead><tr><th># Pedido</th><th>Cliente</th><th>Total</th><th>Estado</th><th>Hora</th></tr></thead>
                        <tbody id="recentOrders"></tbody>
                    </table>
                </div>
            </div>

            <!-- ===== POS ===== -->
            <div class="module-content" id="module-pos">
                <div class="pos-container">
                    <div class="pos-products">
                        <div class="pos-header">
                            <div class="search-box">
                                <i class="fas fa-search"></i>
                                <input type="text" id="productSearch" placeholder="Buscar producto..." oninput="filterProducts()">
                            </div>
                            <select id="categoryFilter" onchange="filterProducts()">
                                <option value="all">Todas</option>
                            </select>
                        </div>
                        <div class="products-grid" id="productsGrid"></div>
                    </div>
                    <div class="pos-cart">
                        <div class="cart-header">
                            <h4>🛒 Pedido #<span id="orderNumber">0001</span></h4>
                            <button class="clear-btn" onclick="clearCart()"><i class="fas fa-trash-alt"></i></button>
                        </div>
                        <div class="client-selector" onclick="openClientSelector()" id="clientSelector">
                            <span class="client-icon">👤</span>
                            <div class="client-info">
                                <span class="client-name" id="selectedClientName">Consumidor Final</span>
                                <span class="client-doc" id="selectedClientDoc"></span>
                                <span class="client-level" id="selectedClientLevel"></span>
                            </div>
                            <span class="client-arrow"><i class="fas fa-chevron-down"></i></span>
                        </div>
                        <div class="cart-items" id="cartItems">
                            <div style="text-align:center;color:var(--text-light);padding:40px 0;font-size:14px;">
                                <i class="fas fa-shopping-cart" style="font-size:32px;display:block;margin-bottom:10px;opacity:0.3;"></i>
                                Carrito vacío
                            </div>
                        </div>
                        <div class="cart-summary">
                            <div class="summary-row"><span>Subtotal</span><span id="subtotal">$0.00</span></div>
                            <div class="summary-row" id="deliveryRow" style="display:none;">
                                <span>Delivery <span class="edit-delivery" onclick="editDelivery()">✏️</span></span>
                                <span id="deliveryAmount">$0.00</span>
                            </div>
                            <div class="summary-row"><span>IVA (<span id="ivaRateDisplay">15</span>%)</span><span id="ivaAmount">$0.00</span></div>
                            <div class="summary-row total"><span>Total</span><span id="totalAmount">$0.00</span></div>
                        </div>
                        <div class="cart-actions">
                            <button class="btn-order-type" onclick="toggleOrderType()" id="orderTypeBtn">📍 Local</button>
                            <button class="btn-pay" id="payBtn" onclick="openPaymentModal()" disabled>
                                <i class="fas fa-credit-card"></i> Cobrar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== COCINA ===== -->
            <div class="module-content" id="module-kitchen">
                <div style="margin-bottom:16px;display:flex;gap:12px;flex-wrap:wrap;">
                    <button onclick="showQRForAll()" style="padding:10px 20px;background:var(--primary);color:white;border:none;border-radius:8px;cursor:pointer;font-weight:600;transition:var(--transition);">
                        <i class="fas fa-qrcode"></i> Ver QR de todos
                    </button>
                    <button onclick="openScanner()" style="padding:10px 20px;background:var(--info);color:white;border:none;border-radius:8px;cursor:pointer;font-weight:600;transition:var(--transition);">
                        <i class="fas fa-camera"></i> Escanear QR para entregar
                    </button>
                </div>
                <div class="kitchen-grid">
                    <div class="kitchen-column">
                        <h4><i class="fas fa-clock" style="color:var(--warning)"></i> Pendientes <span id="pendingCount" style="font-size:12px;color:var(--text-light);">0</span></h4>
                        <div id="kitchenPending"></div>
                    </div>
                    <div class="kitchen-column">
                        <h4><i class="fas fa-utensils" style="color:var(--info)"></i> En preparación <span id="preparingCount" style="font-size:12px;color:var(--text-light);">0</span></h4>
                        <div id="kitchenPreparing"></div>
                    </div>
                    <div class="kitchen-column">
                        <h4><i class="fas fa-check-circle" style="color:var(--success)"></i> Listos <span id="readyCount" style="font-size:12px;color:var(--text-light);">0</span></h4>
                        <div id="kitchenReady"></div>
                    </div>
                </div>
            </div>

            <!-- ===== SCAN QR ===== -->
            <div class="module-content" id="module-scan">
                <div class="orders-card">
                    <div class="section-title">
                        <h3><i class="fas fa-qrcode"></i> Escanear QR para verificar entrega</h3>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
                        <div>
