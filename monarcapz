        // ========================================================
        // PAYMENT
        // ========================================================
        function openPaymentModal() {
            if (cart.length === 0) {
                showNotification('error', '⚠️', 'Carrito vacío', 'Agrega productos para continuar');
                return;
            }
            const total = parseFloat(document.getElementById('totalAmount').textContent.replace('$', ''));
            document.getElementById('modalTotal').textContent = '$' + total.toFixed(2);
            document.getElementById('amountReceived').value = total.toFixed(2);
            document.getElementById('changeDisplay').textContent = '$0.00';

            document.getElementById('paymentClientName').value = selectedClient ? selectedClient.name :
            'Consumidor Final';
            document.getElementById('paymentClientDoc').value = selectedClient && selectedClient.doc ? selectedClient.doc :
            '-';

            document.getElementById('paymentModal').classList.add('show');
        }

        function closePaymentModal() {
            document.getElementById('paymentModal').classList.remove('show');
        }

        function calculateChange() {
            const total = parseFloat(document.getElementById('modalTotal').textContent.replace('$', ''));
            const received = parseFloat(document.getElementById('amountReceived').value) || 0;
            const change = received - total;
            document.getElementById('changeDisplay').textContent = '$' + (change > 0 ? change.toFixed(2) : '0.00');
        }

        function processPayment() {
            const total = parseFloat(document.getElementById('modalTotal').textContent.replace('$', ''));
            const received = parseFloat(document.getElementById('amountReceived').value) || 0;
            if (received < total) {
                showNotification('error', '⚠️', 'Monto insuficiente', 'El monto recibido es menor al total');
                return;
            }

            const clientName = document.getElementById('paymentClientName').value || 'Consumidor Final';
            const clientDoc = document.getElementById('paymentClientDoc').value || '';
            const paymentMethod = document.getElementById('paymentMethod').value;
            const subtotal = cart.reduce((sum, i) => sum + (i.price * i.qty), 0);
            const delivery = orderType === 'delivery' ? deliveryValue : 0;
            const iva = (subtotal + delivery) * (ivaRate / 100);

            let client = null;
            if (clientName !== 'Consumidor Final') {
                client = clients.find(c =>
                    c.name.toLowerCase() === clientName.toLowerCase() ||
                    (c.doc && c.doc === clientDoc && clientDoc)
                );

                if (!client && clientDoc) {
                    client = clients.find(c => c.doc === clientDoc);
                }

                if (!client) {
                    const type = clientDoc ? (clientDoc.length === 10 ? 'cedula' : clientDoc.length === 13 ? 'ruc' :
                        'empresa') : 'consumidor_final';
                    client = {
                        id: Date.now(),
                        name: clientName,
                        doc: clientDoc || '',
                        phone: selectedClient && selectedClient.phone ? selectedClient.phone : '',
                        email: '',
                        address: selectedClient && selectedClient.address ? selectedClient.address : '',
                        reference: '',
                        type: type,
                        purchases: 0,
                        points: 0,
                        level: 'bronce'
                    };
                    clients.push(client);
                    showNotification('success', '🆕', 'Cliente registrado', '"' + clientName + '" automáticamente');
                } else {
                    showNotification('info', '👤', 'Cliente existente', '"' + clientName + '" ya está registrado');
                }
            }

            if (client) {
                client.purchases = (client.purchases || 0) + 1;
                const pointsEarned = Math.floor(total);
                client.points = (client.points || 0) + pointsEarned;

                if (client.points >= 200) client.level = 'diamante';
                else if (client.points >= 100) client.level = 'oro';
                else if (client.points >= 50) client.level = 'plata';
                else client.level = 'bronce';

                showNotification('success', '⭐', 'Puntos ganados', '+' + pointsEarned + ' puntos para ' + client.name);
            }

            const order = {
                id: Date.now(),
                number: orderCounter++,
                client: clientName,
                clientDoc: clientDoc || '',
                items: cart.map(i => ({ id: i.id, name: i.name, price: i.price, qty: i.qty })),
                subtotal: subtotal,
                delivery: delivery,
                iva: iva,
                total: total,
                paymentMethod: paymentMethod,
                type: orderType,
                status: 'pending',
                date: new Date().toISOString(),
                change: received - total,
                clientId: client ? client.id : null,
                pointsEarned: client ? Math.floor(total) : 0,
                clientLevel: client ? client.level : 'bronce'
            };

            orders.push(order);
            kitchenOrders.push({
                id: order.id,
                number: order.number,
                items: order.items,
                type: order.type,
                status: 'pending',
                date: order.date,
                table: null
            });

            // Notificación con sonido
            playNotificationSound();
            showNotification('warning', '🔔', 'Nuevo pedido', 'Pedido #' + String(order.number).padStart(4, '0') +
                ' - ' + clientName);

            cart = [];
            closePaymentModal();
            renderAll();

            const orderNum = String(order.number).padStart(4, '0');
            showNotification('success', '🎉', 'Pedido procesado', '#' + orderNum + ' - Total: $' + total.toFixed(2));

            setTimeout(() => {
                showTicket(order);
            }, 500);

            // Imprimir automáticamente si está configurado
            if (selectedPrinter === 'thermal' && printerDetected) {
                setTimeout(() => {
                    printTicketReal();
                }, 1000);
            }

            console.log('🖨️ TICKET DE VENTA');
            console.log('═══════════════════════════════');
            console.log(`  🏰 ${localStorage.getItem('monarca_businessName') || 'Pizzería Monarca'}`);
            console.log(`  ${localStorage.getItem('monarca_businessAddress') || 'Ambato, Ecuador'}`);
            console.log(`  RUC: ${localStorage.getItem('monarca_businessRuc') || '1234567890001'}`);
            console.log('═══════════════════════════════');
            console.log(`  Pedido #${orderNum}`);
            console.log(`  Cliente: ${clientName}`);
            console.log(`  Documento: ${clientDoc || 'N/A'}`);
            console.log(`  Fecha: ${new Date().toLocaleString('es-EC')}`);
            console.log(`  Tipo: ${orderType}`);
            console.log(`  Puntos: ${client ? Math.floor(total) : 0}`);
            console.log(`  Nivel: ${client ? client.level : 'bronce'}`);
            console.log('───────────────────────────────');
            order.items.forEach(i => {
                console.log(`  ${i.qty}x ${i.name}  $${(i.price * i.qty).toFixed(2)}`);
            });
            if (delivery > 0) console.log(`  Delivery  $${delivery.toFixed(2)}`);
            console.log('───────────────────────────────');
            console.log(`  Subtotal: $${subtotal.toFixed(2)}`);
            console.log(`  IVA (${ivaRate}%): $${iva.toFixed(2)}`);
            console.log(`  TOTAL: $${total.toFixed(2)}`);
            console.log(`  Pago: ${paymentMethod}`);
            console.log(`  Cambio: $${(received - total).toFixed(2)}`);
            console.log('═══════════════════════════════');
            console.log(`  ${localStorage.getItem('monarca_ticketMessage') || '¡Gracias por su visita! 🍕'}`);
            console.log('═══════════════════════════════');
            console.log('📱 QR para entrega:');
            console.log(JSON.stringify({ orderId: order.id, number: order.number }));
        }

        // ========================================================
        // QR FUNCTIONS
        // ========================================================
        function generateQR(orderId) {
            const order = orders.find(o => o.id === orderId);
            if (!order) return null;
            const data = {
                orderId: order.id,
                number: order.number,
                client: order.client,
                total: order.total,
                date: order.date,
                status: order.status
            };
            return JSON.stringify(data);
        }

        function showQR(orderId) {
            const order = orders.find(o => o.id === orderId);
            if (!order) {
                showNotification('error', '❌', 'Pedido no encontrado', '');
                return;
            }

            const qrData = generateQR(orderId);
            if (!qrData) return;

            document.getElementById('qrOrderNumber').textContent = String(order.number).padStart(4, '0');
            document.getElementById('qrOrderDetails').textContent =
                `Cliente: ${order.client || 'Consumidor Final'} | Total: $${order.total.toFixed(2)} | Nivel: ${order.clientLevel || 'bronce'}`;

            const qrContainer = document.getElementById('qrcode');
            qrContainer.innerHTML = '';
            new QRCode(qrContainer, {
                text: qrData,
                width: 200,
                height: 200,
                colorDark: '#5C2E0A',
                colorLight: '#FFFFFF',
                correctLevel: QRCode.CorrectLevel.H
            });

            currentQRData = order;
            document.getElementById('qrModal').classList.add('show');
        }

        function showQRForAll() {
            if (kitchenOrders.length === 0) {
                showNotification('warning', '⚠️', 'No hay pedidos en cocina', '');
                return;
            }
            const first = kitchenOrders.find(o => o.status === 'pending' || o.status === 'preparing' || o.status === 'ready');
            if (first) {
                showQR(first.id);
            } else {
                showNotification('warning', '⚠️', 'No hay pedidos activos', '');
            }
        }

        function closeQRModal() {
            document.getElementById('qrModal').classList.remove('show');
            currentQRData = null;
        }

        function printTicketQR() {
            if (currentQRData) {
                showTicket(currentQRData);
                closeQRModal();
            }
        }

        // ========================================================
        // SCANNER QR
        // ========================================================
        function openScanner() {
            switchModule('scan');
            setTimeout(() => startScanner(), 500);
        }

        function startScanner() {
            const container = document.getElementById('scanner-container');
            const placeholder = document.getElementById('scanner-placeholder');

            if (html5QrCode) {
                stopScanner();
            }

            try {
                html5QrCode = new Html5Qrcode("scanner-container");
                const config = { fps: 10, qrbox: { width: 250, height: 250 }, aspectRatio: 1.0 };

                html5QrCode.start({ facingMode: "environment" },
                    config,
                    onScanSuccess,
                    onScanError
                );

                if (placeholder) placeholder.style.display = 'none';
                showNotification('success', '📷', 'Escáner iniciado', 'Apunte a un código QR');
            } catch (err) {
                console.error('Error al iniciar escáner:', err);
                showNotification('warning', '⚠️', 'No se pudo acceder a la cámara', 'Usando modo archivo');
                useFileScanner();
            }
        }

        function useFileScanner() {
            const container = document.getElementById('scanner-container');
            container.innerHTML = `
                        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:320px;background:#1a1a1a;color:white;gap:16px;padding:20px;">
                            <i class="fas fa-image" style="font-size:48px;opacity:0.5;"></i>
                            <p style="font-size:14px;opacity:0.7;">Sube una imagen con código QR</p>
                            <input type="file" accept="image/*" id="qrFileInput" style="padding:10px;background:white;color:#333;border-radius:8px;border:none;cursor:pointer;">
                        </div>
                    `;

            document.getElementById('qrFileInput').addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const img = new Image();
                        img.onload = function() {
                            try {
                                const canvas = document.createElement('canvas');
                                canvas.width = img.width;
                                canvas.height = img.height;
                                const ctx = canvas.getContext('2d');
                                ctx.drawImage(img, 0, 0);
                                const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                                const code = jsQR(imageData.data, imageData.width, imageData.height);
                                if (code && code.data) {
                                    onScanSuccess(code.data);
                                } else {
                                    showNotification('error', '❌', 'No se encontró QR', 'En la imagen');
                                }
                            } catch (err) {
                                showNotification('error', '❌', 'Error al procesar imagen', '');
                            }
                        };
                        img.src = event.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });
        }

        function stopScanner() {
            if (html5QrCode) {
                try {
                    html5QrCode.stop().then(() => {
                        html5QrCode = null;
                        const placeholder = document.getElementById('scanner-placeholder');
                        if (placeholder) placeholder.style.display = 'flex';
                        showNotification('info', '⏹️', 'Escáner detenido', '');
                    });
                } catch (err) {
                    console.error('Error al detener escáner:', err);
                }
            }
        }

        function onScanSuccess(decodedText) {
            try {
                const data = JSON.parse(decodedText);
                if (data.orderId) {
                    handleQRScan(data);
                } else {
                    showNotification('error', '❌', 'QR inválido', 'No es un pedido');
                }
            } catch (e) {
                const orderNum = parseInt(decodedText);
                if (!isNaN(orderNum)) {
                    const order = orders.find(o => o.number === orderNum);
                    if (order) {
                        handleQRScan({ orderId: order.id, number: order.number });
                    } else {
                        showNotification('error', '❌', 'Pedido no encontrado', '');
                    }
                } else {
                    showNotification('error', '❌', 'QR inválido', '');
                }
            }
        }

        function onScanError(err) {}

        function handleQRScan(data) {
            const order = orders.find(o => o.id === data.orderId || o.number === data.number);
            if (!order) {
                showNotification('error', '❌', 'Pedido no encontrado', '');
                addScanHistory(false, data.number || '?', 'Pedido no encontrado');
                return;
            }

            if (order.status === 'delivered') {
                showNotification('warning', '✅', 'Pedido ya entregado', '#' + String(order.number).padStart(4, '0'));
                addScanHistory(true, order.number, 'Ya entregado');
                return;
            }

            // Mostrar modal de confirmación de entrega (sin alert)
            showDeliveryConfirmation(order);
        }

        function showDeliveryConfirmation(order) {
            // Crear modal de confirmación personalizado
            const overlay = document.createElement('div');
            overlay.className = 'modal-overlay show';
            overlay.id = 'deliveryConfirmModal';
            overlay.innerHTML = `
                        <div class="modal" style="max-width:450px;">
                            <h2><i class="fas fa-check-circle" style="color:var(--success)"></i> Confirmar Entrega</h2>
                            <div style="text-align:center;padding:16px 0;">
                                <div style="font-size:48px;margin-bottom:12px;">📦</div>
                                <p style="font-size:18px;font-weight:700;color:var(--primary-dark);">
                                    Pedido #${String(order.number).padStart(4,'0')}
                                </p>
                                <p style="color:var(--text-light);margin:8px 0;">
                                    Cliente: <strong>${order.client || 'Consumidor Final'}</strong>
                                </p>
                                <p style="color:var(--text-light);margin:8px 0;">
                                    Total: <strong>$${order.total.toFixed(2)}</strong>
                                </p>
                                <p style="color:var(--text-light);margin:8px 0;">
                                    Estado actual: <span class="status-badge ${order.status}">${order.status}</span>
                                </p>
                                ${order.clientLevel ? `<p style="color:var(--text-light);margin:8px 0;">
                                    Nivel: <span class="loyalty-badge ${order.clientLevel}">${order.clientLevel}</span>
                                </p>` : ''}
                                <div style="margin:16px 0;padding:12px;background:var(--secondary);border-radius:8px;">
                                    <p style="font-size:13px;color:var(--text-light);">
                                        <i class="fas fa-info-circle"></i> 
                                        ¿Confirmar la entrega de este pedido?
                                    </p>
                                </div>
                            </div>
                            <div class="modal-actions">
                                <button class="btn-confirm" onclick="confirmDelivery(${order.id})">
                                    <i class="fas fa-check"></i> Confirmar Entrega
                                </button>
                                <button class="btn-cancel" onclick="closeDeliveryConfirm()">
                                    Cancelar
                                </button>
                            </div>
                        </div>
                    `;
            document.body.appendChild(overlay);
        }

        function closeDeliveryConfirm() {
            const modal = document.getElementById('deliveryConfirmModal');
            if (modal) {
                modal.classList.remove('show');
                setTimeout(() => modal.remove(), 300);
            }
        }

        function confirmDelivery(orderId) {
            const order = orders.find(o => o.id === orderId);
            if (!order) {
                showNotification('error', '❌', 'Pedido no encontrado', '');
                closeDeliveryConfirm();
                return;
            }

            if (order.status === 'delivered') {
                showNotification('warning', '✅', 'Pedido ya entregado', '#' + String(order.number).padStart(4, '0'));
                closeDeliveryConfirm();
                return;
            }

            // Entregar pedido
            order.status = 'delivered';
            const kitchenOrder = kitchenOrders.find(o => o.id === order.id);
            if (kitchenOrder) {
                kitchenOrder.status = 'delivered';
                setTimeout(() => {
                    const idx = kitchenOrders.findIndex(o => o.id === order.id);
                    if (idx > -1) kitchenOrders.splice(idx, 1);
                    renderAll();
                }, 500);
            }

            // Actualizar puntos del cliente
            const client = clients.find(c => c.name === order.client);
            if (client && order.pointsEarned) {
                client.points = (client.points || 0) + order.pointsEarned;
                if (client.points >= 200) client.level = 'diamante';
                else if (client.points >= 100) client.level = 'oro';
                else if (client.points >= 50) client.level = 'plata';
                else client.level = 'bronce';
            }

            renderAll();
            showNotification('success', '🎉', 'Pedido entregado', '#' + String(order.number).padStart(4, '0') +
                ' - ' + order.client);
            addScanHistory(true, order.number, 'Entregado correctamente');

            closeDeliveryConfirm();
            setTimeout(() => showTicket(order), 300);
        }

        function addScanHistory(success, orderNumber, message) {
            scanHistory.push({
                success: success,
                orderNumber: orderNumber,
                message: message,
                time: new Date().toISOString()
            });
            localStorage.setItem('monarca_scanHistory', JSON.stringify(scanHistory));
            loadScanHistory();
        }

