        function saveClient() {
            const id = document.getElementById('editClientId').value;
            const name = document.getElementById('clientNameInput').value.trim();
            const doc = document.getElementById('clientDoc').value.trim();

            if (!name) {
                showNotification('error', '⚠️', 'El nombre es requerido', '');
                return;
            }

            let duplicate = null;
            if (name) {
                duplicate = clients.find(c =>
                    c.name.toLowerCase() === name.toLowerCase() &&
                    c.id != id &&
                    c.name !== 'Consumidor Final'
                );
            }
            if (!duplicate && doc) {
                duplicate = clients.find(c =>
                    c.doc === doc &&
                    c.id != id &&
                    c.doc !== ''
                );
            }

            if (duplicate) {
                showNotification('error', '⚠️', 'Cliente ya registrado',
                    '"' + duplicate.name + '" ya existe en el sistema');
                document.getElementById('duplicateAlert').classList.add('show');
                document.getElementById('duplicateMessage').textContent =
                    `⚠️ Cliente "${duplicate.name}" ya está registrado (${duplicate.doc || 'sin documento'})`;
                return;
            }

            const clientData = {
                name: name,
                type: document.getElementById('clientType').value,
                doc: doc,
                phone: document.getElementById('clientPhone').value.trim(),
                email: document.getElementById('clientEmail').value.trim(),
                address: document.getElementById('clientAddress').value.trim(),
                reference: document.getElementById('clientReference').value.trim(),
                purchases: 0,
                points: 0,
                level: 'bronce'
            };

            if (id) {
                const index = clients.findIndex(c => c.id == id);
                if (index > -1) {
                    clients[index] = { ...clients[index], ...clientData };
                }
                showNotification('success', '✅', 'Cliente actualizado', name);
            } else {
                clientData.id = Date.now();
                clients.push(clientData);
                showNotification('success', '✅', 'Cliente agregado', name);
                if (document.getElementById('clientSelectorModal').classList.contains('show')) {
                    selectedClient = { ...clientData };
