        function addToCart(productId) {
            const product = products.find(p => p.id === productId);
            if (!product) return;
            if (product.stock <= 0) {
                showNotification('error', '⚠️', 'Sin stock', product.name + ' no tiene stock disponible');
                return;
            }
            const existing = cart.find(item => item.id === productId);
            if (existing) {
                existing.qty++;
            } else {
                cart.push({ id: productId, name: product.name, price: product.price, qty: 1 });
            }
            // Reducir stock y actualizar ingredientes
            product.stock--;
            updateIngredientsFromProduct(product);
            renderAll();
            showNotification('success', '✅', 'Producto agregado', product.name + ' al carrito');
        }

        function updateIngredientsFromProduct(product) {
            // Asociar producto con ingredientes (simplificado)
            const productIngredients = {
                'Pizza Personal': ['Harina de Trigo', 'Queso Mozzarella', 'Salsa de Tomate'],
                'Pizza Mediana': ['Harina de Trigo', 'Queso Mozzarella', 'Salsa de Tomate'],
                'Pizza Familiar': ['Harina de Trigo', 'Queso Mozzarella', 'Salsa de Tomate'],
                'Pizza Suprema': ['Harina de Trigo', 'Queso Mozzarella', 'Salsa de Tomate', 'Pepperoni', 'Jamón'],
                'Extra Queso': ['Queso Mozzarella'],
                'Extra Pepperoni': ['Pepperoni'],
            };

            const ingredientNames = productIngredients[product.name] || [];
            ingredientNames.forEach(name => {
                const ingredient = ingredients.find(i => i.name === name);
                if (ingredient) {
                    ingredient.stock = Math.max(0, ingredient.stock - 0.1);
                    if (ingredient.stock <= ingredient.minStock) {
                        showNotification('warning', '⚠️', 'Stock bajo', `${ingredient.name} está por terminarse`);
                    }
                }
            });
        }

        function updateCartQty(idx, delta) {
            if (idx < 0 || idx >= cart.length) return;
            const item = cart[idx];
            item.qty += delta;
            if (item.qty <= 0) {
                const product = products.find(p => p.id === item.id);
                if (product) product.stock += item.qty + 1;
                cart.splice(idx, 1);
            } else {
                const product = products.find(p => p.id === item.id);
                if (product) product.stock -= delta;
            }
            renderAll();
        }

        function removeFromCart(idx) {
            if (idx < 0 || idx >= cart.length) return;
            const item = cart[idx];
            const product = products.find(p => p.id === item.id);
            if (product) product.stock += item.qty;
            cart.splice(idx, 1);
            renderAll();
            showNotification('info', '🗑️', 'Producto removido', 'Del carrito');
        }

        function clearCart() {
            if (cart.length === 0) return;
            cart.forEach(item => {
                const product = products.find(p => p.id === item.id);
                if (product) product.stock += item.qty;
            });
            cart = [];
            renderAll();
            showNotification('info', '🗑️', 'Carrito vaciado', 'Todos los productos fueron removidos');
        }

