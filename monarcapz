        function generateESCPOSData() {
            // Generar datos ESC/POS reales
            const text = document.getElementById('ticketPreview').innerText;
            const encoder = new TextEncoder();
            const data = [];

            // ESC/POS comandos
            data.push(0x1B, 0x40); // Inicializar impresora
            data.push(0x1B, 0x61, 0x01); // Centrar
            data.push(...encoder.encode(text));
            data.push(0x0A, 0x0A); // Saltos de línea
            data.push(0x1B, 0x64, 0x04); // Avanzar papel
            data.push(0x1B, 0x69); // Cortar papel

            return new Uint8Array(data);
        }

        function generateTicketPDF() {
            showNotification('info', '📄', 'Generando PDF...', 'Espere un momento');
            setTimeout(() => {
                const ticketContent = document.getElementById('ticketPreview');
                if (ticketContent) {
                    html2canvas(ticketContent, {
                        scale: 2,
                        backgroundColor: '#ffffff',
                        logging: false
                    }).then(canvas => {
                        const imgData = canvas.toDataURL('image/png');
                        const { jsPDF } = window.jspdf;
                        const doc = new jsPDF('p', 'mm', 'a4');
                        const imgWidth = 80;
                        const imgHeight = (canvas.height * imgWidth) / canvas.width;
                        doc.addImage(imgData, 'PNG', 65, 30, imgWidth, imgHeight);
                        doc.save(`Ticket_${document.getElementById('ticketNumber').textContent}.pdf`);
                        showNotification('success', '✅', 'PDF descargado', 'Ticket guardado correctamente');
                        setTimeout(() => closeTicketModal(), 500);
                    }).catch(err => {
                        showNotification('error', '❌', 'Error al generar PDF', err.message);
                    });
                }
            }, 300);
        }

