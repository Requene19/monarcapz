        function checkDuplicateClient() {
            const name = document.getElementById('clientNameInput').value.trim();
            const doc = document.getElementById('clientDoc').value.trim();
            const editId = document.getElementById('editClientId').value;
            const alertDiv = document.getElementById('duplicateAlert');
            const msgSpan = document.getElementById('duplicateMessage');

            if (!name && !doc) {
                alertDiv.classList.remove('show');
                return;
            }

            let duplicate = null;
            if (name) {
                duplicate = clients.find(c =>
                    c.name.toLowerCase() === name.toLowerCase() &&
                    c.id != editId &&
                    c.name !== 'Consumidor Final'
                );
            }
            if (!duplicate && doc) {
                duplicate = clients.find(c =>
                    c.doc === doc &&
                    c.id != editId &&
                    c.doc !== ''
                );
            }

            if (duplicate) {
                alertDiv.classList.add('show');
                msgSpan.textContent =
                    `⚠️ Cliente "${duplicate.name}" ya está registrado (${duplicate.doc || 'sin documento'})`;
            } else {
                alertDiv.classList.remove('show');
            }
        }

