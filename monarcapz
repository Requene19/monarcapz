        // ========================================================
        function updateKitchenStatus(orderId, status) {
            const order = kitchenOrders.find(o => o.id === orderId);
            if (!order) return;
            order.status = status;

            const mainOrder = orders.find(o => o.id === orderId);
            if (mainOrder) {
                if (status === 'preparing') mainOrder.status = 'preparing';
                if (status === 'ready') mainOrder.status = 'ready';
                if (status === 'delivered') {
                    mainOrder.status = 'delivered';
                    setTimeout(() => {
                        const idx = kitchenOrders.findIndex(o => o.id === orderId);
                        if (idx > -1) kitchenOrders.splice(idx, 1);
                        renderAll();
                    }, 500);
                }
            }

            renderAll();
            const statusNames = { pending: 'Pendiente', preparing: 'En preparación', ready: 'Listo',
            delivered: 'Entregado' };
            showNotification('info', '📋', 'Pedido ' + statusNames[status], '#' + String(order.number).padStart(4,
            '0'));

            if (status === 'ready') {
                playNotificationSound();
                showNotification('success', '✅', 'Pedido listo', '#' + String(order.number).padStart(4, '0'));
            }

            if (status === 'preparing') {
                showNotification('info', '👨‍🍳', 'Preparando pedido', '#' + String(order.number).padStart(4, '0'));
            }
        }

